# Application Environment
APP_ENV=development

# Database Configuration (MySQL)
DB_HOST=mysql
DB_PORT=3306
DB_NAME=fastapi_pos
DB_USER=pos_user
DB_PASSWORD=pos_password_123

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# SMTP (optional — required for customer OTP emails to leave the server)
# Leave SMTP_HOST empty to skip email (use development_otp in API when APP_ENV=development).
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM_EMAIL=noreply@example.com
# SMTP_USE_TLS=true
# SMTP_USE_SSL=false

# MySQL Root Password (for Docker)
MYSQL_ROOT_PASSWORD=root_password_123
